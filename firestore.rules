rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      // For now, allow the user who provided the config
      return isAuthenticated() && (request.auth.token.email == 'd49web@gmail.com');
    }

    match /posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
