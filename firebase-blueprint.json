{
  "entities": {
    "Post": {
      "title": "Blog Post",
      "description": "A blog post or podcast episode",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "excerpt": { "type": "string" },
        "date": { "type": "string" },
        "author": { "type": "string" },
        "category": { "type": "string" },
        "readingTime": { "type": "string" },
        "coverImage": { "type": "string" },
        "type": { "type": "string", "enum": ["blog", "podcast"] },
        "audioUrl": { "type": "string" }
      },
      "required": ["title", "content", "date", "type"]
    }
  },
  "firestore": {
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Collection of all blog posts and podcast episodes"
    }
  }
}
